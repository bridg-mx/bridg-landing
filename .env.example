# Supabase Postgres connection (Dashboard → Connect → ORMs → Prisma).
#
# DATABASE_URL  — pooled connection (Supavisor, port 6543), used at runtime.
# DIRECT_URL    — direct/session connection (port 5432), used for migrations.
#
# Replace [PASSWORD] with the database password and [REGION] with your
# project's region (e.g. us-east-1). YOUR-PROJECT-REF is the Supabase ref.
DATABASE_URL="postgresql://postgres.YOUR-PROJECT-REF:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR-PROJECT-REF:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"
